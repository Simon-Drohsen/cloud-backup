{% extends 'base.html.twig' %}

{% block content %}
    <section class="uk-section uk-section-default">
        <div class="uk-container uk-container-large">
            <h1>Dateien</h1>

            {{ include('base/flash-messages.html.twig') }}

            {% set isCompanyTab = activeTab == 'company' and canAccessCompanyFiles %}
            {% set currentUploadForm = isCompanyTab ? companyUploadForm : personalUploadForm %}
            {% set currentFolderForm = isCompanyTab ? companyFolderForm : personalFolderForm %}
            {% set currentFiles = isCompanyTab ? companyFiles : personalFiles %}
            {% set currentFolders = isCompanyTab ? companyFolders : personalFolders %}
            {% set currentMoveTargetFolders = isCompanyTab ? companyMoveTargetFolders : personalMoveTargetFolders %}
            {% set currentDownloadRoute = isCompanyTab ? 'app_company_files_download' : 'app_member_files_download' %}
            {% set currentFileDeleteRoute = isCompanyTab ? 'app_company_files_delete' : 'app_member_files_delete' %}
            {% set currentFolderDeleteRoute = isCompanyTab ? 'app_company_files_delete_folder' : 'app_member_files_delete_folder' %}
            {% set currentFileMoveRoute = isCompanyTab ? 'app_company_files_move' : 'app_member_files_move' %}
            {% set currentIndexRoute = isCompanyTab ? 'app_company_files_index' : 'app_member_files_index' %}
            {% set csrfScope = isCompanyTab ? 'company' : 'personal' %}

            <div class="uk-margin-small-bottom uk-text-meta">
                {% if parentFolderId is not null %}
                    <span>Aktueller Ordner: </span>
                    {% for breadcrumb in currentBreadcrumbs %}
                        {% if loop.last %}
                            <span>{{ breadcrumb.name }}</span>
                        {% else %}
                            <a href="{{ path(currentIndexRoute, {folder: breadcrumb.id}) }}">{{ breadcrumb.name }}</a> /
                        {% endif %}
                    {% endfor %}
                    <a class="uk-margin-left" href="{{ path(currentIndexRoute, {folder: parentFolderId}) }}">Zurück</a>
                {% else %}
                    <span>Aktueller Ordner: {{ currentFolderName }}</span>
                {% endif %}
            </div>

            {% if not currentUploadForm.vars.valid %}
                <div class="uk-alert uk-alert-danger" data-uk-alert>
                    <a class="uk-alert-close" data-uk-close></a>
                    {{ form_errors(currentUploadForm) }}
                    {{ form_errors(currentUploadForm.file) }}
                </div>
            {% endif %}

            {% if not currentFolderForm.vars.valid %}
                <div class="uk-alert uk-alert-danger" data-uk-alert>
                    <a class="uk-alert-close" data-uk-close></a>
                    {{ form_errors(currentFolderForm) }}
                    {{ form_errors(currentFolderForm.name) }}
                </div>
            {% endif %}

            <div class="uk-card uk-card-default uk-card-body">
                <h2 class="uk-card-title">{{ isCompanyTab ? 'Dateien deiner Firma' : 'Deine Dateien' }}</h2>
                <div class="uk-margin-medium-bottom uk-flex uk-flex-wrap uk-flex-middle uk-grid-small" data-uk-grid>
                    <div>
                        <button class="uk-button uk-button-primary" type="button" data-uk-toggle="target: #upload-modal">
                            Datei hochladen
                        </button>
                    </div>
                    <div>
                        <button class="uk-button uk-button-secondary" type="button" data-uk-toggle="target: #create-folder-modal">
                            Ordner erstellen
                        </button>
                    </div>
                </div>

                {% if currentFolders is empty and currentFiles is empty %}
                    <p class="uk-text-muted uk-margin-remove">Noch keine Dateien vorhanden.</p>
                {% else %}
                    <table class="uk-table uk-table-divider uk-table-middle member-files-table">
                        <thead>
                            <tr>
                                <th>Dateiname</th>
                                <th>Typ</th>
                                <th>Upload</th>
                                <th>Grösse</th>
                                <th class="uk-text-right">Aktion</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for folder in currentFolders %}
                                <tr>
                                    <td>
                                        <a href="{{ path(currentIndexRoute, {folder: folder.id}) }}">{{ folder.filename }}</a>
                                    </td>
                                    <td>Ordner</td>
                                    <td>{{ folder.creationDate|date('d.m.Y H:i') }}</td>
                                    <td>-</td>
                                    <td class="uk-text-right">
                                        <form method="post" action="{{ path(currentFolderDeleteRoute, {folderId: folder.id}) }}" class="uk-display-inline">
                                            <input type="hidden" name="folderId" value="{{ currentFolderId }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ csrfScope ~ '-folder-' ~ folder.id) }}">
                                            <button type="submit" class="uk-button uk-button-danger uk-button-small">Ordner löschen</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}

                            {% for file in currentFiles %}
                                <tr>
                                    <td>{{ file.filename }}</td>
                                    <td>Datei</td>
                                    <td>{{ file.creationDate|date('d.m.Y H:i') }}</td>
                                    <td>
                                        {% set sizeInBytes = file.fileSize %}
                                        {% if sizeInBytes >= 1073741824 %}
                                            {{ (sizeInBytes / 1073741824)|number_format(2, ',', '.') }} GB
                                        {% else %}
                                            {{ (sizeInBytes / 1048576)|number_format(2, ',', '.') }} MB
                                        {% endif %}
                                    </td>
                                    <td class="uk-text-right">
                                        <a class="uk-button uk-button-default uk-button-small" href="{{ path(currentDownloadRoute, {assetId: file.id}) }}">
                                            Download
                                        </a>
                                        <form method="post" action="{{ path(currentFileMoveRoute, {assetId: file.id}) }}" class="uk-display-inline">
                                            <input type="hidden" name="folderId" value="{{ currentFolderId }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('move-' ~ csrfScope ~ '-file-' ~ file.id) }}">
                                            <select name="targetFolderId" class="uk-select uk-form-small uk-width-small">
                                                {% for targetFolder in currentMoveTargetFolders %}
                                                    <option value="{{ targetFolder.id }}" {{ targetFolder.id == file.parentId ? 'selected' : '' }}>{{ targetFolder.label }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" class="uk-button uk-button-secondary uk-button-small">Verschieben</button>
                                        </form>

                                        <form method="post" action="{{ path(currentFileDeleteRoute, {assetId: file.id}) }}" class="uk-display-inline">
                                            <input type="hidden" name="folderId" value="{{ currentFolderId }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete-' ~ csrfScope ~ '-file-' ~ file.id) }}">
                                            <button type="submit" class="uk-button uk-button-danger uk-button-small">Datei löschen</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>

            <div id="upload-modal" data-uk-modal>
                <div class="uk-modal-dialog uk-modal-body">
                    <button class="uk-modal-close-default" type="button" data-uk-close></button>
                    <h2 class="uk-modal-title">Datei hochladen</h2>
                    {{ form_start(currentUploadForm, {attr: {enctype: 'multipart/form-data', 'data-upload-progress-form': 'true'}}) }}
                        <input type="hidden" name="folderId" value="{{ currentFolderId }}">
                        {{ form_errors(currentUploadForm) }}
                        {{ form_row(currentUploadForm.file) }}
                        <altcha-widget
                            challenge="{{ path('app_altcha_challenge', {context: isCompanyTab ? 'member_files_upload_company' : 'member_files_upload_personal'}) }}"
                            auto="onsubmit"
                            name="altcha"
                        ></altcha-widget>
                        <div class="upload-progress" data-upload-progress>
                            <progress class="uk-progress" value="0" max="100" data-upload-progress-bar></progress>
                            <p class="uk-text-meta upload-progress__label" data-upload-progress-label>Upload: 0%</p>
                            <p class="uk-text-danger upload-progress__error" data-upload-progress-error hidden></p>
                        </div>
                        <button class="uk-button uk-button-primary" type="submit">Hochladen</button>
                    {{ form_end(currentUploadForm) }}
                </div>
            </div>

            <div id="create-folder-modal" data-uk-modal>
                <div class="uk-modal-dialog uk-modal-body">
                    <button class="uk-modal-close-default" type="button" data-uk-close></button>
                    <h2 class="uk-modal-title">Ordner erstellen</h2>
                    {{ form_start(currentFolderForm) }}
                        <input type="hidden" name="folderId" value="{{ currentFolderId }}">
                        {{ form_errors(currentFolderForm) }}
                        {{ form_row(currentFolderForm.name) }}
                        <button class="uk-button uk-button-secondary" type="submit">Ordner erstellen</button>
                    {{ form_end(currentFolderForm) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

